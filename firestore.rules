rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shehbazmaster256@gmail.com' || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------
    // USERS
    // ------------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && incoming().role == 'customer';
      allow update: if isOwner(userId) && 
                    incoming().role == existing().role &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------
    // ADMINS
    // ------------------------------------------------------------
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // ------------------------------------------------------------
    // MENU
    // ------------------------------------------------------------
    match /menu_categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------
    // ORDERS
    // ------------------------------------------------------------
    match /orders/{orderId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || !('userId' in incoming()));
      
      allow update: if isAdmin() ||
                    (isSignedIn() && existing().userId == request.auth.uid && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['status']) && 
                     incoming().status == 'cancelled' && 
                     existing().status == 'pending');
      
      allow delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid);
        allow create: if isSignedIn() && (getAfter(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid);
        allow update, delete: if isAdmin();
      }
    }

    // ------------------------------------------------------------
    // RESERVATIONS
    // ------------------------------------------------------------
    match /reservations/{resId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow get: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if true;
      allow update: if isAdmin() || (isSignedIn() && existing().email == request.auth.token.email && 
                     incoming().status == 'cancelled' && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------
    // REVIEWS / BANNERS / SETTINGS / COUPONS
    // ------------------------------------------------------------
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /coupons/{couponId} {
      allow read: if isAdmin() || (isSignedIn() && existing().active == true);
      allow write: if isAdmin();
    }
  }
}
